{
  "realm": "rag",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator — full access to ingestion, sources, jobs"
      },
      {
        "name": "user",
        "description": "Regular user — search only"
      }
    ]
  },
  "clients": [
    {
      "clientId": "rag-app",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "rootUrl": "http://localhost",
      "baseUrl": "/",
      "redirectUris": ["http://localhost/*", "http://localhost:80/*", "*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "default-roles-rag"]
    },
    {
      "username": "user",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "default-roles-rag"]
    }
  ]
}
